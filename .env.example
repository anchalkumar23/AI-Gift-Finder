# Copy this to .env on the VPS (next to docker-compose.yml) and fill in real values.
# Never commit the real .env file.

OPENAI_API_KEY=sk-your-key-here
PEXELS_API_KEY=your-pexels-key-here

# Origins allowed to call the backend directly (CORS). With nginx fronting both
# services on one host, normal browser traffic is same-origin and doesn't need this,
# but it's kept as a safety net for any direct backend access.
ALLOWED_ORIGINS=http://187.77.158.215

# Leave empty unless the frontend is ever deployed on a different origin than the
# backend (see docker-compose.yml's comment on this same variable).
NEXT_PUBLIC_API_URL=
